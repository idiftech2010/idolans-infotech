{
  "buildCommand": "pnpm install --frozen-lockfile && PORT=3000 BASE_PATH=/ pnpm --dir artifacts/idolans build",
  "outputDirectory": "artifacts/idolans/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://your-render-api-url.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
